# Path to the GenEval Mask2Former detector checkpoint.
JAX_GENEVAL_DETECTOR_CKPT=/path/to/mask2former_swin-s-p4-w7-224_lsj_8x2_50e_coco.pth

# Optional: path to a JAX CLIP repo/package exposing `jclip.clip`.
JAX_CLIP_REPO=/path/to/legacy/jax-clip

# Optional: mmdetection 2.x checkout for parity scripts.
MMDET_ROOT=/path/to/mmdetection

# Optional: virtualenv site-packages containing mmcv/mmdet dependencies.
GENEVAL_VENV_SITE=/path/to/venv/lib/python3.10/site-packages
